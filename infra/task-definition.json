{
    "family": "url-shortener",
    "taskRoleArn": "arn:aws:iam::447170313597:role/url-shortener-20260419113152949500000002",
    "executionRoleArn": "arn:aws:iam::447170313597:role/url-shortener-20260419113152950400000004",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "containerDefinitions": [
        {
            "name": "url-shortener",
            "image": "447170313597.dkr.ecr.ap-southeast-2.amazonaws.com/url-shortener:latest",
            "cpu": 256,
            "memory": 512,
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/aws/ecs/url-shortener/url-shortener",
                    "awslogs-region": "ap-southeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "environment": [],
            "mountPoints": [],
            "volumesFrom": []
        }
    ]
}
